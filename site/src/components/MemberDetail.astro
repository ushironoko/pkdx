---
import MemberCard from './MemberCard.astro';
import DamageCalcTable from './DamageCalcTable.astro';
import type { TeamMember, DamageCalc } from '../lib/team-meta';

interface Props {
  member: TeamMember;
  index: number;
  calcs: DamageCalc[];
}

const { member, index, calcs } = Astro.props;
---
<section class="member-detail" id={`member-${index + 1}`}>
  <MemberCard member={member} />

  {member.role && (
    <div class="member-detail-body">
      <p>{member.role}</p>
    </div>
  )}

  {calcs.length > 0 && (
    <DamageCalcTable calcs={calcs} heading="ダメージ計算" headingLevel={4} />
  )}
</section>

<style>
  .member-detail {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--c-border);
    content-visibility: auto;
    contain-intrinsic-size: 1px 600px;
  }
  .member-detail:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .member-detail-body p {
    margin: 0;
    white-space: pre-wrap;
  }
</style>
