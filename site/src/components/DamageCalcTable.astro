---
import type { DamageCalc } from '../lib/team-meta';

interface Props {
  calcs: DamageCalc[];
  heading?: string;
  headingLevel?: 2 | 3 | 4;
}

const { calcs, heading = 'ダメージ計算', headingLevel = 2 } = Astro.props;
const HeadingTag = `h${headingLevel}` as 'h2' | 'h3' | 'h4';

function hitsLabel(n: number | null | undefined): string {
  if (n == null) return '';
  if (n === 1) return '確1';
  if (n === 2) return '確2';
  if (n === 3) return '確3';
  return `確${n}`;
}

function formatPercent(n: number | null | undefined): string {
  if (n == null) return '-';
  return `${n.toFixed(1)}%`;
}

function formatRanks(ranks: Record<string, number> | null | undefined): string {
  if (!ranks) return '';
  const labelMap: Record<string, string> = {
    atk: 'A',
    def: 'B',
    spa: 'C',
    spd: 'D',
    spe: 'S',
  };
  const parts = Object.entries(ranks)
    .filter(([, v]) => v !== 0)
    .map(([k, v]) => `${labelMap[k] ?? k}${v > 0 ? '+' : ''}${v}`);
  return parts.join(' ');
}

function formatConditions(conditions: DamageCalc['conditions']): string[] {
  if (!conditions) return [];
  const parts: string[] = [];
  if (conditions.weather) parts.push(conditions.weather);
  if (conditions.field) parts.push(`${conditions.field}フィールド`);
  if (conditions.crit) parts.push('急所');
  return parts;
}
---
{calcs.length > 0 && (
  <section class="damage-calcs">
    {heading && <HeadingTag>{heading}</HeadingTag>}
    <article class="calc-card">
      {calcs.map((calc) => {
        const attackerRanks = formatRanks(calc.attacker.ranks);
        const defenderRanks = formatRanks(calc.defender.ranks);
        const conditionsParts = formatConditions(calc.conditions);
        return (
        <div class="calc-entry">
          {calc.title && <h4 class="calc-title">{calc.title}</h4>}
          <div class="calc-header">
            <div class="calc-side">
              <span class="side-label">攻撃</span>
              <strong class="side-name">{calc.attacker.name ?? '-'}</strong>
              <div class="side-detail">
                {calc.attacker.tera_type && (
                  <span class="tera">テラス: {calc.attacker.tera_type}</span>
                )}
                {(calc.attacker.ability || calc.attacker.nature) && (
                  <span class="muted small">
                    {[calc.attacker.ability, calc.attacker.nature].filter(Boolean).join(' / ')}
                  </span>
                )}
                {calc.attacker.item && <span class="muted small">@ {calc.attacker.item}</span>}
                {attackerRanks && <span class="muted small">ランク: {attackerRanks}</span>}
              </div>
            </div>
            <div class="calc-move">
              <span class="side-label" aria-hidden="true">&nbsp;</span>
              <span class="side-name move-name">{calc.move.name}</span>
              <div class="side-detail">
                <span class="muted small">
                  {calc.move.type} / {calc.move.category}{calc.move.power ? ` / 威力${calc.move.power}` : ''}
                </span>
              </div>
            </div>
            <div class="calc-side">
              <span class="side-label">防御</span>
              <strong class="side-name">{calc.defender.name ?? '-'}</strong>
              <div class="side-detail">
                {calc.defender.tera_type && (
                  <span class="tera">テラス: {calc.defender.tera_type}</span>
                )}
                {(calc.defender.ability || calc.defender.nature) && (
                  <span class="muted small">
                    {[calc.defender.ability, calc.defender.nature].filter(Boolean).join(' / ')}
                  </span>
                )}
                {calc.defender.item && <span class="muted small">@ {calc.defender.item}</span>}
                {calc.defender.hp_stat != null && (
                  <span class="muted small">HP実数値: {calc.defender.hp_stat}</span>
                )}
                {defenderRanks && <span class="muted small">ランク: {defenderRanks}</span>}
              </div>
            </div>
          </div>

          {conditionsParts.length > 0 && (
            <p class="calc-conditions">
              {conditionsParts.map((c) => <span class="cond">{c}</span>)}
            </p>
          )}

          {(calc.min_percent != null || calc.max_percent != null || calc.guaranteed_hits != null) && (
            <p class="calc-summary">
              <span class="pct">{formatPercent(calc.min_percent)} 〜 {formatPercent(calc.max_percent)}</span>
              {calc.guaranteed_hits != null && <span class="hits">{hitsLabel(calc.guaranteed_hits)}</span>}
            </p>
          )}

          {calc.rolls_percent.length > 0 && (
            <div class="rolls-scroll">
              <table class="rolls-table">
                <thead>
                  <tr>{calc.rolls_percent.map((_, i) => <th>{i + 1}</th>)}</tr>
                </thead>
                <tbody>
                  <tr>{calc.rolls_percent.map((r) => <td>{r.toFixed(1)}</td>)}</tr>
                </tbody>
              </table>
            </div>
          )}

          {calc.note && <p class="calc-note">{calc.note}</p>}
        </div>
        );
      })}
    </article>
  </section>
)}

<style>
  .calc-card {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 20px;
    corner-shape: superellipse(1.5);
    padding: 1rem;
  }
  .calc-entry {
    content-visibility: auto;
    contain-intrinsic-size: 1px 240px;
  }
  .calc-entry + .calc-entry {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--c-border);
  }
  .calc-title { margin: 0 0 0.5rem 0; font-size: 1rem; }
  .move-name { font-weight: 600; }
  .calc-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-rows: auto auto auto;
    column-gap: 0.75rem;
    row-gap: 0.15rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--c-border);
  }
  /* 攻撃 / 技 / 防御 の 3 カラムそれぞれを親 grid の 3 行に subgrid で
     揃える。結果、side-label / name / detail がカラム横断で同じ行に揃う。 */
  .calc-side,
  .calc-move {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: 1 / span 3;
    row-gap: 0.15rem;
  }
  .calc-side:last-child { text-align: right; }
  .calc-move { text-align: center; padding: 0 0.5rem; }
  .side-label {
    font-size: 0.7rem;
    color: var(--c-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .side-name { line-height: 1.3; }
  .side-detail {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .calc-conditions {
    margin: 0.5rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.75rem;
  }
  .cond {
    background: var(--c-surface-alt, rgba(0,0,0,0.05));
    color: var(--c-text-muted);
    padding: 0.1em 0.55em;
    border-radius: 999px;
  }
  .tera {
    font-size: 0.75rem;
    color: var(--c-accent);
    font-weight: 600;
  }
  .calc-summary {
    margin: 0.5rem 0 0.75rem;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .pct { font-variant-numeric: tabular-nums; font-size: 1.1rem; font-weight: 600; }
  .hits {
    background: var(--c-accent-bg);
    color: var(--c-accent);
    padding: 0.1em 0.6em;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .rolls-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .rolls-table {
    display: table;
    width: 100%;
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    margin: 0;
    white-space: nowrap;
  }
  .rolls-table th, .rolls-table td {
    text-align: center;
    vertical-align: middle;
    padding: 0 0.25rem;
    height: 2rem;
    line-height: 2rem;
  }
  .rolls-table th {
    background: transparent;
    color: var(--c-text-muted);
    font-weight: 600;
  }
  .calc-note {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    color: var(--c-text-muted);
    white-space: pre-wrap;
  }
  .small { font-size: 0.8rem; }
</style>
