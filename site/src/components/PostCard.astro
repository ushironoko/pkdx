---
import type { BlogFrontmatter } from '../content.config';

interface Props {
  slug: string;
  data: BlogFrontmatter;
}

const { slug, data } = Astro.props;
const base = import.meta.env.BASE_URL;
const dateStr = data.date.toISOString().slice(0, 10);
---
<a class="post-card" href={`${base}blog/${encodeURIComponent(slug)}/`}>
  <time datetime={dateStr} class="muted small">{dateStr}</time>
  <h3 class="post-title">{data.title}</h3>
  {data.description && <p class="post-desc">{data.description}</p>}
  {data.tags.length > 0 && (
    <div class="post-tags">
      {data.tags.map((t) => <span class="tag">#{t}</span>)}
    </div>
  )}
</a>

<style>
  .post-card {
    display: block;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    padding: 1rem;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .post-card:hover { border-color: var(--c-accent); text-decoration: none; }
  .post-title { margin: 0.25rem 0; font-size: 1.15rem; }
  .post-desc { margin: 0.25rem 0; font-size: 0.9rem; color: var(--c-text-muted); }
  .post-tags { margin-top: 0.5rem; }
  .small { font-size: 0.8rem; }
</style>
