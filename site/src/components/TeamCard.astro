---
import type { PublishedTeamData } from '../content.config';

interface Props {
  slug: string;
  data: PublishedTeamData;
}

const { slug, data } = Astro.props;
const base = import.meta.env.BASE_URL;
const dateStr = data.date.toISOString().slice(0, 10);
---
<a
  class="team-card"
  href={`${base}teams/${encodeURIComponent(slug)}/`}
  transition:name={`team-card-${slug}`}
>
  <div class="card-head">
    <time datetime={dateStr} class="muted small">{dateStr}</time>
  </div>
  <h3 class="card-title">{data.title}</h3>
  <div class="card-meta">
    <span class="tag">{data.battle_format === 'doubles' ? 'ダブル' : 'シングル'}</span>
    <span class="tag">{data.mechanics}</span>
    {data.regulation && <span class="tag">{data.regulation}</span>}
  </div>
  <p class="members small muted">{data.members.join(' / ')}</p>
  {data.description && <p class="description">{data.description}</p>}
</a>

<style>
  .team-card {
    display: block;
    padding: 1rem 0;
    color: inherit;
    text-decoration: none;
  }
  .team-card:hover {
    text-decoration: none;
    color: var(--c-text);
  }
  .team-card:hover .card-title {
    color: var(--c-text);
    text-decoration: underline;
  }
  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.25rem;
  }
  .card-title {
    margin: 0.25rem 0;
    font-size: 1.15rem;
    transition: color 0.15s;
  }
  .card-meta { display: flex; flex-wrap: wrap; gap: 0.25rem; margin: 0.5rem 0; }
  .members { margin: 0.25rem 0 0; }
  .description { margin: 0.5rem 0 0; font-size: 0.9rem; }
  .small { font-size: 0.8rem; }
</style>
