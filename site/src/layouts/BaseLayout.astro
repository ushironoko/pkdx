---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import SiteHeader from '../components/SiteHeader.astro';
import { loadSiteConfig } from '../lib/site-config';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const config = loadSiteConfig();
const pageTitle = title ? `${title} - ${config.site_name}` : config.site_name;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (() => {
        const storageKey = 'theme';
        const root = document.documentElement;
        const apply = (theme) => {
          root.dataset.theme = theme;
          root.style.colorScheme = theme;
        };
        const resolve = () => {
          const saved = localStorage.getItem(storageKey);
          if (saved === 'light' || saved === 'dark') return saved;
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        };
        apply(resolve());
        window.__applyTheme = apply;
        window.__resolveTheme = resolve;
      })();
      document.addEventListener('astro:after-swap', () => {
        window.__applyTheme(window.__resolveTheme());
      });
    </script>
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <Font cssVariable="--font-ibm-plex-sans-jp" preload />
    <ClientRouter />
  </head>
  <body>
    <SiteHeader transition:persist />

    <main class="container">
      <slot />
    </main>

    <footer class="container muted" transition:persist>
      {config.author ? <small>© {config.author}</small> : <small>pkdx teams</small>}
    </footer>

    <style>
      footer { border-top: 1px solid var(--c-border); margin-top: 3rem; padding-top: 1rem; }
    </style>
  </body>
</html>
