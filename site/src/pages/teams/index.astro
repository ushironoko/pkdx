---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamCard from '../../components/TeamCard.astro';
import { isPublishableTeam } from '../../content.config';

const sortKey = (d: { publishedAt?: Date; date: Date }) =>
  (d.publishedAt ?? d.date).getTime();
const teams = (await getCollection('teams'))
  .filter(isPublishableTeam)
  .sort((a, b) => sortKey(b.data) - sortKey(a.data));
---
<BaseLayout title="構築一覧">
  <h1>構築一覧</h1>
  {teams.length === 0 ? (
    <p class="empty-state">まだ構築記事がありません。<code>pkdx write teams</code> で生成した MD が <code>box/teams/</code> に入ると自動で公開されます。</p>
  ) : (
    <div class="list">
      {teams.map((entry) => <TeamCard slug={entry.id} data={entry.data} />)}
    </div>
  )}
</BaseLayout>

<style>
  .list {
    display: flex;
    flex-direction: column;
  }
</style>
