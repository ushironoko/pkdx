import {
  "pkdxtools/pkdx/src/model",
  "moonbitlang/core/json" @json,
  "moonbitlang/x/sys",
}

options(
  "supported-targets": "native",
  "native-stub": [ "cwrap.c", "sqlite3.c" ],
  link: {
    "native": {
      "stub-cc-flags": "-DSQLITE_THREADSAFE=0 -DSQLITE_OMIT_LOAD_EXTENSION -DSQLITE_DQS=0 -O2",
    },
  },
)